{
  "name": "@dept/components-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "DEPT brand UI library — framework-agnostic core with per-framework packages (React, Vue, Svelte)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/dept/hold-apb-component-library.git"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.7.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "build": "turbo run build",
    "build:watch": "turbo watch build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "build-storybook": "turbo run build-storybook",
    "dev": "turbo run dev --filter=@dept/storybook",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "turbo": "^2.5.0",
    "typescript-eslint": "^8.56.0"
  }
}
