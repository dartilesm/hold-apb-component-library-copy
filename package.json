{
  "name": "@dept/component-library",
  "version": "0.1.0",
  "description": "DEPT shared React component library — shadcn/ui on Base UI primitives with sealed, namespaced styling",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build --config vite.lib.config.ts",
    "build:watch": "vite build --config vite.lib.config.ts --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "yalc:publish": "pnpm run build && yalc publish --push",
    "yalc:watch": "nodemon --watch src --ext ts,tsx,css --exec 'pnpm run yalc:publish'",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dept/hold-apb-component-library.git"
  },
  "publishConfig": {
    "@dept:registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.7.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "license": "UNLICENSED",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "nodemon": "^3.1.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup-preserve-directives": "^1.1.3",
    "shadcn": "^4.13.0",
    "storybook": "^10.5.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
