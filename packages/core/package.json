{
  "name": "@dept/core",
  "version": "0.1.0",
  "description": "DEPT brand design tokens, compiled stylesheet, variant recipes and prop contracts — the framework-agnostic substrate shared by @dept/react, @dept/vue and @dept/svelte",
  "type": "module",
  "types": "./dist/index.d.ts",
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./styles/globals.css": "./src/styles/globals.css",
    "./recipes": {
      "types": "./dist/recipes/index.d.ts",
      "import": "./dist/recipes/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    },
    "./cn": {
      "types": "./dist/cn.d.ts",
      "import": "./dist/cn.js"
    },
    "./story-specs/*": "./src/story-specs/*.ts"
  },
  "files": ["dist", "src/styles/globals.css", "src/story-specs"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dept/hold-apb-component-library.git"
  },
  "license": "UNLICENSED",
  "scripts": {
    "build:js": "vite build --config vite.lib.config.ts",
    "build:css": "tailwindcss -i ./src/styles/styles.css -o ./dist/styles.css --minify",
    "build": "pnpm run build:js && pnpm run build:css",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
