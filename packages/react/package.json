{
  "name": "@dartilesm/react",
  "version": "0.0.0",
  "description": "DEPT React component library — shadcn/ui on Base UI primitives, styled from @dartilesm/core",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "sideEffects": ["**/*.css"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dartilesm/hold-apb-component-library-copy.git"
  },
  "license": "UNLICENSED",
  "scripts": {
    "build": "vite build --config vite.lib.config.ts && node ./scripts/copy-core-styles.mjs",
    "build:watch": "vite build --config vite.lib.config.ts --watch",
    "typecheck": "tsc --noEmit",
    "yalc:publish": "pnpm run build && yalc publish --push",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dartilesm/core": "workspace:^",
    "lucide-react": "^1.24.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup-preserve-directives": "^1.1.3",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
